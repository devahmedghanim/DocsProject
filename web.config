<?xml version="1.0" encoding="UTF-8"?>
<!--
  Nexus PMS Documentation — IIS configuration

  What this does:
  1) Maps /PrivateSettings to the admin panel (admin/index.html)
  2) Raises upload size limits so video files can be uploaded from the admin panel
  3) Registers MIME types for .json/.mp4/.webm/.mov in case they are missing on the server
  4) Sets index.html as the default document

  Requirements on the IIS server:
  - "URL Rewrite" module installed (free Microsoft module) for the /PrivateSettings rule
  - PHP installed and registered as a Handler Mapping (FastCGI) for the /api/*.php scripts
    (ask your server admin, or install "PHP Manager for IIS")
-->
<configuration>
  <system.webServer>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
        <!-- //#region Edit By AI -->
        <add value="index.php" />
        <!-- //#endregion Edit By AI -->
      </files>
    </defaultDocument>

    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".mp4" />
      <mimeMap fileExtension=".mp4" mimeType="video/mp4" />
      <remove fileExtension=".webm" />
      <mimeMap fileExtension=".webm" mimeType="video/webm" />
      <remove fileExtension=".mov" />
      <mimeMap fileExtension=".mov" mimeType="video/quicktime" />
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>

    <!-- Allow larger uploads (videos) — adjust as needed, value in bytes (200MB here) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="209715200" />
        <!-- //#region Edit By AI -->
        <hiddenSegments>
          <add segment="private" />
        </hiddenSegments>
        <!-- //#endregion Edit By AI -->
      </requestFiltering>
    </security>

    <rewrite>
      <rules>
        <rule name="PrivateSettings to Admin Panel" stopProcessing="true">
          <match url="^PrivateSettings/?$" />
          <action type="Rewrite" url="admin/portal.php" />
        </rule>
        <!-- //#region Edit By AI -->
        <rule name="Admin Direct Access Gate" stopProcessing="true">
          <match url="^(admin/?|admin/index\.html)$" />
          <action type="Rewrite" url="admin/portal.php" />
        </rule>
        <!-- //#endregion Edit By AI -->
        <!-- //#region Edit By AI -->
        <rule name="Documentation Clean Routes" stopProcessing="true">
          <match url="^(?!api/|assets/|data/|uploads/|admin/).+" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
        <!-- //#endregion Edit By AI -->
      </rules>
    </rewrite>

  </system.webServer>

  <!--
    If PHP uploads still fail with large files, also raise these in your php.ini:
      upload_max_filesize = 200M
      post_max_size = 210M
      max_execution_time = 300
  -->
</configuration>
