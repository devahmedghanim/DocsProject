<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>NexusPms.Api</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="7.0.20" />
  </ItemGroup>

  <Target Name="CopySpaToWwwroot" AfterTargets="Publish">
    <ItemGroup>
      <SpaFiles
        Include="$(MSBuildProjectDirectory)/../dist/frontend/**"
        Exclude="$(MSBuildProjectDirectory)/../dist/frontend/API/**" />
    </ItemGroup>
    <Copy
      SourceFiles="@(SpaFiles)"
      DestinationFiles="@(SpaFiles->'$(PublishDir)wwwroot/%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
      Condition="'@(SpaFiles)' != ''" />
  </Target>
</Project>
